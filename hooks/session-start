#!/usr/bin/env bash
# SessionStart hook for Fellowship plugin
# Injects fellowship-bootstrap.md plus optional project-level context files:
#   - docs/fellowship/quest-log.md  (if file exists)
#   - docs/fellowship/product.md    (if it has real content; otherwise a notice)
#
# Note: learnings.md is no longer injected — each agent has native persistent memory
# (memory: project) that accumulates domain-specific knowledge across sessions.
#
# Each file is wrapped in a labeled XML tag and combined into one additionalContext string.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Determine project cwd — prefer $CWD env var, fall back to $(pwd)
PROJECT_CWD="${CWD:-$(pwd)}"
FELLOWSHIP_DIR="${PROJECT_CWD}/docs/fellowship"

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass — orders of magnitude
# faster than a character-by-character loop.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# ── 1. fellowship-bootstrap.md (always) ──────────────────────────────────────
bootstrap_content=$(cat "${PLUGIN_ROOT}/hooks/fellowship-bootstrap.md" 2>/dev/null || echo "Error reading fellowship-bootstrap.md")
if [ -z "$bootstrap_content" ]; then
    bootstrap_content="Error: hooks/fellowship-bootstrap.md is empty or could not be read"
fi
bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<FELLOWSHIP_CONTEXT>\\n${bootstrap_escaped}\\n</FELLOWSHIP_CONTEXT>"

# ── 2. quest-log.md (if file exists) ─────────────────────────────────────────
QUEST_LOG="${FELLOWSHIP_DIR}/quest-log.md"
if [ -f "$QUEST_LOG" ]; then
    quest_content=$(cat "$QUEST_LOG" 2>/dev/null || echo "")
    if [ -n "$quest_content" ]; then
        quest_escaped=$(escape_for_json "$quest_content")
        session_context="${session_context}\\n<QUEST_LOG>\\n${quest_escaped}\\n</QUEST_LOG>"
    fi
fi

# ── 3. product.md (real content check) ───────────────────────────────────────
# "Real content" = any line that is not empty, not a markdown comment (<!--),
# and not a section heading (##) followed by an empty line.
# Strategy: strip blank lines, comment lines (<!-- ... -->), and heading lines (##),
# then check if anything remains.
PRODUCT="${FELLOWSHIP_DIR}/product.md"
if [ -f "$PRODUCT" ]; then
    product_raw=$(cat "$PRODUCT" 2>/dev/null || echo "")
    # Filter out: empty lines, lines starting with <!--, lines starting with ##
    product_real=$(printf '%s\n' "$product_raw" | grep -v '^\s*$' | grep -v '^\s*<!--' | grep -v '^\s*##' || true)
    if [ -n "$product_real" ]; then
        product_escaped=$(escape_for_json "$product_raw")
        session_context="${session_context}\\n<PRODUCT_CONTEXT>\\n${product_escaped}\\n</PRODUCT_CONTEXT>"
    else
        notice="product.md has no content yet — ask the user to describe the project before starting work"
        notice_escaped=$(escape_for_json "$notice")
        session_context="${session_context}\\n<PRODUCT_CONTEXT>\\n${notice_escaped}\\n</PRODUCT_CONTEXT>"
    fi
fi

# ── Output context as JSON ────────────────────────────────────────────────────
# Cursor hooks expect additional_context.
# Claude Code hooks expect hookSpecificOutput.additionalContext.
# Claude Code reads BOTH fields without deduplication, so we must only
# emit the field consumed by the current platform to avoid double injection.
#
# Uses printf instead of heredoc (cat <<EOF) to work around a bash 5.3+
# bug where heredoc variable expansion hangs when content exceeds ~512 bytes.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT) — emit additional_context
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT — emit only hookSpecificOutput
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Other platforms — emit additional_context as fallback
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
