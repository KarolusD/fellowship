#!/usr/bin/env bash
# SessionStart hook for Fellowship plugin
# Injects fellowship-bootstrap.md plus optional project-level context files:
#   - docs/fellowship/quest-log.md  (if file exists)
#   - docs/fellowship/product.md    (if it has real content; otherwise a notice)
#
# Note: learnings.md is no longer injected — each agent has native persistent memory
# (memory: project) that accumulates domain-specific knowledge across sessions.
#
# Each file is wrapped in a labeled XML tag and combined into one additionalContext string.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Determine project cwd — prefer $CWD env var, fall back to $(pwd)
PROJECT_CWD="${CWD:-$(pwd)}"
FELLOWSHIP_DIR="${PROJECT_CWD}/docs/fellowship"

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass — orders of magnitude
# faster than a character-by-character loop.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# ── 1. fellowship-bootstrap.md (always) ──────────────────────────────────────
bootstrap_content=$(cat "${PLUGIN_ROOT}/hooks/fellowship-bootstrap.md" 2>/dev/null || echo "Error reading fellowship-bootstrap.md")
if [ -z "$bootstrap_content" ]; then
    bootstrap_content="Error: hooks/fellowship-bootstrap.md is empty or could not be read"
fi
bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<FELLOWSHIP_CONTEXT>\\n${bootstrap_escaped}\\n</FELLOWSHIP_CONTEXT>"

# ── 2. quest-log.md (if file exists) ─────────────────────────────────────────
QUEST_LOG="${FELLOWSHIP_DIR}/quest-log.md"
if [ -f "$QUEST_LOG" ]; then
    quest_content=$(cat "$QUEST_LOG" 2>/dev/null || echo "")
    if [ -n "$quest_content" ]; then
        quest_escaped=$(escape_for_json "$quest_content")
        session_context="${session_context}\\n<QUEST_LOG>\\n${quest_escaped}\\n</QUEST_LOG>"
    fi
fi

# ── 3. product.md (real content check) ───────────────────────────────────────
# "Real content" = any line that is not empty, not a markdown comment (<!--),
# and not a heading (# or ##) followed by an empty line.
# Strategy: strip blank lines, comment lines (<!-- ... -->), and heading lines (# or ##),
# then check if anything remains.
PRODUCT="${FELLOWSHIP_DIR}/product.md"
if [ -f "$PRODUCT" ]; then
    product_raw=$(cat "$PRODUCT" 2>/dev/null || echo "")
    # Filter out: empty lines, lines starting with <!--, lines starting with # (any heading level)
    product_real=$(printf '%s\n' "$product_raw" | grep -v '^\s*$' | grep -v '^\s*<!--' | grep -v '^\s*#' || true)
    if [ -n "$product_real" ]; then
        product_escaped=$(escape_for_json "$product_raw")
        session_context="${session_context}\\n<PRODUCT_CONTEXT>\\n${product_escaped}\\n</PRODUCT_CONTEXT>"
    else
        notice="product.md has no content yet — ask the user to describe the project before starting work"
        notice_escaped=$(escape_for_json "$notice")
        session_context="${session_context}\\n<PRODUCT_CONTEXT>\\n${notice_escaped}\\n</PRODUCT_CONTEXT>"
    fi
fi

# ── 4. debug-log.md (last ~3 entries if file exists and non-empty) ───────────
DEBUG_LOG="${FELLOWSHIP_DIR}/debug-log.md"
if [ -f "$DEBUG_LOG" ]; then
    debug_raw=$(tail -60 "$DEBUG_LOG" 2>/dev/null || echo "")
    if [ -n "$debug_raw" ]; then
        debug_escaped=$(escape_for_json "$debug_raw")
        session_context="${session_context}\\n<DEBUG_LOG>\\n${debug_escaped}\\n</DEBUG_LOG>"
    fi
fi

# ── 5. Most recent handoff (if written within last 7 days) ───────────────────
HANDOFFS_DIR="${FELLOWSHIP_DIR}/handoffs"
if [ -d "$HANDOFFS_DIR" ]; then
    recent_handoff=$(find "$HANDOFFS_DIR" -name "*.md" -mtime -7 -type f 2>/dev/null \
        | sort -r | head -1 || true)
    if [ -n "$recent_handoff" ]; then
        handoff_raw=$(cat "$recent_handoff" 2>/dev/null || echo "")
        if [ -n "$handoff_raw" ]; then
            handoff_name=$(basename "$recent_handoff")
            handoff_escaped=$(escape_for_json "$handoff_raw")
            session_context="${session_context}\\n<HANDOFF file=\"${handoff_name}\">\\n${handoff_escaped}\\n</HANDOFF>"
        fi
    fi
fi

# ── 6. codebase-map.md (first 30 lines if file exists) ───────────────────────
CODEBASE_MAP="${FELLOWSHIP_DIR}/codebase-map.md"
if [ -f "$CODEBASE_MAP" ]; then
    map_raw=$(head -30 "$CODEBASE_MAP" 2>/dev/null || echo "")
    if [ -n "$map_raw" ]; then
        map_escaped=$(escape_for_json "$map_raw")
        session_context="${session_context}\\n<CODEBASE_MAP>\\n${map_escaped}\\n</CODEBASE_MAP>"
    fi
fi

# ── 7. Ethos absence check (P4) ──────────────────────────────────────────────
ETHOS_FILE="${PROJECT_CWD}/templates/ethos.md"
if [ -d "$FELLOWSHIP_DIR" ] && [ ! -f "$ETHOS_FILE" ]; then
    notice="Ethos missing. Run \`/fellowship:add-ethos\` to add the four Fellowship Principles to templates/ethos.md."
    notice_escaped=$(escape_for_json "$notice")
    session_context="${session_context}\\n<ETHOS_NOTICE>\\n${notice_escaped}\\n</ETHOS_NOTICE>"
fi

# ── 8. Project-local skills and agents survey (P6) ───────────────────────────
CLAUDE_DIR="${PROJECT_CWD}/.claude"
if [ -d "$CLAUDE_DIR" ]; then
    skill_count=0
    agent_count=0
    skill_names=""
    agent_names=""

    if [ -d "$CLAUDE_DIR/skills" ]; then
        while IFS= read -r name; do
            [ -n "$name" ] || continue
            skill_names="${skill_names}${name}, "
            skill_count=$((skill_count + 1))
        done < <(find "$CLAUDE_DIR/skills" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; 2>/dev/null)
    fi

    if [ -d "$CLAUDE_DIR/agents" ]; then
        while IFS= read -r name; do
            [ -n "$name" ] || continue
            agent_names="${agent_names}${name}, "
            agent_count=$((agent_count + 1))
        done < <(find "$CLAUDE_DIR/agents" -maxdepth 1 -mindepth 1 -name "*.md" -exec basename {} .md \; 2>/dev/null)
    fi

    if [ $skill_count -gt 0 ] || [ $agent_count -gt 0 ]; then
        skill_names="${skill_names%, }"
        agent_names="${agent_names%, }"

        inventory="Project-local: "
        [ $skill_count -gt 0 ] && inventory="${inventory}${skill_count} skill(s) [${skill_names}]"
        [ $skill_count -gt 0 ] && [ $agent_count -gt 0 ] && inventory="${inventory}, "
        [ $agent_count -gt 0 ] && inventory="${inventory}${agent_count} agent(s) [${agent_names}]"
        inventory="${inventory}. Project-local takes precedence over plugin on name collision."

        inventory_escaped=$(escape_for_json "$inventory")
        session_context="${session_context}\\n<PROJECT_LOCAL>\\n${inventory_escaped}\\n</PROJECT_LOCAL>"
    fi
fi

# ── 9. Quest-log consolidation reminder (P5) ─────────────────────────────────
REMINDER="${FELLOWSHIP_DIR}/.quest-log-reminder"
if [ -f "$REMINDER" ]; then
    reminder_content=$(cat "$REMINDER" 2>/dev/null || echo "")
    if [ -n "$reminder_content" ]; then
        reminder_escaped=$(escape_for_json "$reminder_content")
        session_context="${session_context}\\n<QUEST_LOG_REMINDER>\\n${reminder_escaped}\\n</QUEST_LOG_REMINDER>"
    fi
    rm -f "$REMINDER"  # One-shot notice
fi

# ── Output context as JSON ────────────────────────────────────────────────────
# Cursor hooks expect additional_context.
# Claude Code hooks expect hookSpecificOutput.additionalContext.
# Claude Code reads BOTH fields without deduplication, so we must only
# emit the field consumed by the current platform to avoid double injection.
#
# Uses printf instead of heredoc (cat <<EOF) to work around a bash 5.3+
# bug where heredoc variable expansion hangs when content exceeds ~512 bytes.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT) — emit additional_context
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT — emit only hookSpecificOutput
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Other platforms — emit additional_context as fallback
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
